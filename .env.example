# Database (PostgreSQL on AWS RDS or local)
DATABASE_URL=postgresql://user:password@localhost:5432/sapy_db

# JWT Secrets
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Twilio (Phone OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Phone Auth Alternative)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# Razorpay (India)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Stripe (International)
STRIPE_API_KEY=your-stripe-api-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# License System
LICENSE_PRIVATE_KEY_PATH=/path/to/private_key.pem
LICENSE_PUBLIC_KEY_PATH=/path/to/public_key.pem

# Message Limits (Per Tier)
FREE_TIER_LIMIT=55
BASIC_TIER_LIMIT=155
STANDARD_TIER_LIMIT=555
PREMIUM_TIER_LIMIT=999999

# Pricing (USD)
FREE_PRICE_USD=0.00
BASIC_PRICE_USD=2.90
STANDARD_PRICE_USD=4.90
PREMIUM_PRICE_USD=19.90

# Pricing (INR)
FREE_PRICE_INR=0
BASIC_PRICE_INR=249
STANDARD_PRICE_INR=449
PREMIUM_PRICE_INR=1699

# Email (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Admin
ADMIN_EMAIL=your-email@example.com
ADMIN_DASHBOARD_SECRET=secret-key-for-admin-dashboard

# Environment
ENVIRONMENT=development
DEBUG=True
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "*"]
